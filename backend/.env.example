SECRET_KEY=your-secure-secret-key-min-50-chars-change-this-now
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=stratogarage_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Razorpay — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Gmail SMTP — requires a Google App Password (NOT your account password)
# Setup: myaccount.google.com → Security → 2FA on → App Passwords → Generate
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Stratos Garage <your-gmail@gmail.com>

REDIS_URL=redis://127.0.0.1:6379/0
FRONTEND_URL=http://localhost:5173
DJANGO_LOG_LEVEL=INFO
